# Firebase 클라우드 동기화 설정 (선택)
# 이 값들을 .env.local 파일로 복사해 채우면 Google 로그인 + 기기 간 실시간 동기화가 켜집니다.
# 비워두면 앱은 로컬 모드(브라우저 저장)로 동작합니다.
# 이 값들은 비밀이 아닙니다(클라이언트에 노출되는 공개 설정). Firestore 보안 규칙으로 데이터를 보호합니다.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
